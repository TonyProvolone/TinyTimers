<Window x:Class="TinyTimers.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tiny Timers"
        Icon="Assets/icon.ico"
        Height="480" Width="540"
        MinHeight="360" MinWidth="460"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <DataTemplate x:Key="TimerRowTemplate">
            <Border BorderThickness="1"
                    CornerRadius="6" Padding="12" Margin="0,0,0,8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLinkedAppRunning}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBackgroundBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsForegroundActive}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource ActiveHotkeyBorderBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="&#x1F517;"
                                       FontSize="11"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource IconForegroundBrush}"
                                       ToolTip="{Binding LinkedAppTooltip}"
                                       Visibility="{Binding HasLinkedApp, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Elapsed}" FontFamily="Consolas" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="14" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="{Binding ToggleLabel}"
                            Width="60" Margin="6,0,0,0"
                            Click="Toggle_Click"
                            Tag="{Binding}"
                            Background="{DynamicResource SecondaryButtonBackgroundBrush}"
                            Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                            BorderThickness="0"
                            Cursor="Hand"/>

                    <Button Grid.Column="2"
                            Content="&#x21BA;"
                            Width="26" Margin="4,0,0,0"
                            Click="Reset_Click"
                            Tag="{Binding}"
                            ToolTip="Reset timer"
                            Foreground="{DynamicResource IconForegroundBrush}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"/>

                    <Button Grid.Column="3"
                            Content="&#x1F4C1;"
                            Width="26" Margin="4,0,0,0"
                            Click="RevealFile_Click"
                            Tag="{Binding}"
                            ToolTip="Open the readable text file folder"
                            Foreground="{DynamicResource IconForegroundBrush}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"/>

                    <Button Grid.Column="4"
                            Content="&#x270E;"
                            Width="26" Margin="4,0,0,0"
                            Click="Edit_Click"
                            Tag="{Binding}"
                            ToolTip="Rename or edit timer"
                            Foreground="{DynamicResource IconForegroundBrush}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"/>

                    <Button Grid.Column="5"
                            Content="&#x1F5D1;"
                            Width="26" Margin="4,0,0,0"
                            Click="Remove_Click"
                            Tag="{Binding}"
                            ToolTip="Delete timer"
                            Foreground="{DynamicResource IconForegroundBrush}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="+ Add Timer"
                    Height="36"
                    Click="AddTimerButton_Click"
                    Background="{DynamicResource AccentBackgroundBrush}"
                    Foreground="{DynamicResource AccentForegroundBrush}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Cursor="Hand"/>

            <Button Grid.Column="1"
                    Content="&#x2699;"
                    Width="36" Height="36"
                    Margin="8,0,0,0"
                    Click="OptionsButton_Click"
                    Background="{DynamicResource SecondaryButtonBackgroundBrush}"
                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </Grid>

        <Grid Grid.Row="1">
            <TextBlock x:Name="EmptyStateText"
                       Text="No timers yet. Click &quot;Add Timer&quot; to get started."
                       Foreground="{DynamicResource MutedTextBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <StackPanel x:Name="RegularSection">
                        <TextBlock Text="TIMERS" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SectionHeaderBrush}" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="RegularTimersList" ItemTemplate="{StaticResource TimerRowTemplate}"/>
                    </StackPanel>

                    <StackPanel x:Name="CountdownSection" Margin="0,16,0,0">
                        <TextBlock Text="COUNTDOWNS" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SectionHeaderBrush}" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="CountdownTimersList" ItemTemplate="{StaticResource TimerRowTemplate}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
