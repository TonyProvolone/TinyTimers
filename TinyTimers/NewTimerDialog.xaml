<Window x:Class="TinyTimers.NewTimerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Timer"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI">
    <StackPanel Margin="20" Width="280">
        <TextBlock Text="Timer name" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
        <TextBox x:Name="TimerNameBox"
                 Height="28"
                 Padding="4"
                 MaxLength="30"
                 VerticalContentAlignment="Center"
                 Background="{DynamicResource InputBackgroundBrush}"
                 Foreground="{DynamicResource InputForegroundBrush}"
                 BorderBrush="{DynamicResource InputBorderBrush}"
                 BorderThickness="1"
                 CaretBrush="{DynamicResource InputForegroundBrush}"
                 KeyDown="TimerNameBox_KeyDown"/>

        <TextBlock Text="Timer type" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,16,0,8"/>
        <RadioButton x:Name="RegularTypeRadio" GroupName="TimerType" Content="Regular (counts up)"
                     Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" IsChecked="True"
                     Checked="TimerType_Changed"/>
        <RadioButton x:Name="CountdownTypeRadio" GroupName="TimerType" Content="Countdown"
                     Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4"
                     Checked="TimerType_Changed"/>

        <StackPanel x:Name="CountdownDurationPanel" Visibility="Collapsed" Margin="0,10,0,0">
            <TextBlock Text="Count down from" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBox x:Name="HoursBox" Height="28" Padding="4" TextAlignment="Center"
                             Background="{DynamicResource InputBackgroundBrush}"
                             Foreground="{DynamicResource InputForegroundBrush}"
                             BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1"
                             CaretBrush="{DynamicResource InputForegroundBrush}" Text="0"/>
                    <TextBlock Text="Hours" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBox x:Name="MinutesBox" Height="28" Padding="4" TextAlignment="Center"
                             Background="{DynamicResource InputBackgroundBrush}"
                             Foreground="{DynamicResource InputForegroundBrush}"
                             BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1"
                             CaretBrush="{DynamicResource InputForegroundBrush}" Text="5"/>
                    <TextBlock Text="Minutes" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBox x:Name="SecondsBox" Height="28" Padding="4" TextAlignment="Center"
                             Background="{DynamicResource InputBackgroundBrush}"
                             Foreground="{DynamicResource InputForegroundBrush}"
                             BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1"
                             CaretBrush="{DynamicResource InputForegroundBrush}" Text="0"/>
                    <TextBlock Text="Seconds" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <StackPanel x:Name="SoundPanel" Visibility="Collapsed" Margin="0,16,0,0">
            <TextBlock Text="Sound when finished" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SoundBox"
                         Grid.Column="0"
                         Height="28"
                         Padding="4"
                         IsReadOnly="True"
                         Text="Default ding"
                         VerticalContentAlignment="Center"
                         Background="{DynamicResource InputBackgroundBrush}"
                         Foreground="{DynamicResource InputForegroundBrush}"
                         BorderBrush="{DynamicResource InputBorderBrush}"
                         BorderThickness="1"/>
                <Button Grid.Column="1"
                        Content="Browse..."
                        Width="70" Height="28"
                        Margin="8,0,0,0"
                        Click="BrowseSound_Click"
                        Background="{DynamicResource SecondaryButtonBackgroundBrush}"
                        Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </Grid>
            <Button x:Name="ResetSoundButton"
                    Content="Use default ding"
                    HorizontalAlignment="Left"
                    Margin="0,4,0,0"
                    Padding="0"
                    Visibility="Collapsed"
                    Click="ResetSound_Click"
                    Background="Transparent"
                    Foreground="{DynamicResource LinkTextBrush}"
                    BorderThickness="0"
                    FontSize="11"
                    Cursor="Hand"/>
        </StackPanel>

        <StackPanel x:Name="LinkedAppPanel">
            <TextBlock Text="Linked app (optional)"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Margin="0,16,0,8"
                       ToolTip="Link an app to this timer. This timer will become the active timer when that app is open and focused."/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="LinkedAppBox"
                         Grid.Column="0"
                         Height="28"
                         Padding="4"
                         IsReadOnly="True"
                         Text="None selected"
                         VerticalContentAlignment="Center"
                         Background="{DynamicResource InputBackgroundBrush}"
                         Foreground="{DynamicResource InputForegroundBrush}"
                         BorderBrush="{DynamicResource InputBorderBrush}"
                         BorderThickness="1"/>
                <Button Grid.Column="1"
                        Content="&#x1F517;"
                        Width="28" Height="28"
                        Margin="8,0,0,0"
                        Click="SelectRunningApp_Click"
                        ToolTip="Choose from currently open apps"
                        Background="{DynamicResource SecondaryButtonBackgroundBrush}"
                        Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </Grid>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Button Content="Browse for a file instead"
                        Padding="0" Margin="0,0,12,0"
                        Click="BrowseLinkedApp_Click"
                        Background="Transparent"
                        Foreground="{DynamicResource LinkTextBrush}"
                        BorderThickness="0"
                        FontSize="11"
                        Cursor="Hand"/>
                <Button x:Name="ClearLinkedAppButton"
                        Content="Clear link"
                        Padding="0"
                        Visibility="Collapsed"
                        Click="ClearLinkedApp_Click"
                        Background="Transparent"
                        Foreground="{DynamicResource LinkTextBrush}"
                        BorderThickness="0"
                        FontSize="11"
                        Cursor="Hand"/>
            </StackPanel>
        </StackPanel>

        <TextBlock x:Name="ErrorText"
                   Foreground="{DynamicResource ErrorTextBrush}"
                   FontSize="11"
                   Margin="0,10,0,0"
                   Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel"
                    Width="80" Height="28" Margin="0,0,8,0"
                    Click="Cancel_Click"
                    Background="Transparent"
                    Foreground="{DynamicResource MutedTextBrush}"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Add"
                    Width="80" Height="28"
                    Click="Add_Click"
                    Background="{DynamicResource AccentBackgroundBrush}"
                    Foreground="{DynamicResource AccentForegroundBrush}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>
