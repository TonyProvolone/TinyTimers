<Window x:Class="TinyTimers.OptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Options"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI">
    <StackPanel Margin="20" Width="300">

        <!-- Appearance -->
        <TextBlock Text="APPEARANCE" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SectionHeaderBrush}" Margin="0,0,0,10"/>
        <RadioButton x:Name="DarkThemeRadio" GroupName="Theme" Content="Dark" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
        <RadioButton x:Name="LightThemeRadio" GroupName="Theme" Content="Light" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
        <RadioButton x:Name="SystemThemeRadio" GroupName="Theme" Content="Match system" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,4"
                     ToolTip="Matches current active OS system theme"/>

        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,16,0,16"/>

        <!-- System -->
        <TextBlock Text="SYSTEM" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SectionHeaderBrush}" Margin="0,0,0,10"/>
        <CheckBox x:Name="RunOnStartupCheck"
                  Content="Run on startup"
                  Foreground="{DynamicResource PrimaryTextBrush}"
                  Margin="0,0,0,10"
                  ToolTip="Launches Tiny Timers in the background on startup"/>

        <CheckBox x:Name="MinimizeToTaskbarCheck"
                  Content="Minimize to taskbar when closed"
                  Foreground="{DynamicResource PrimaryTextBrush}"
                  Margin="0,0,0,10"
                  ToolTip="Minimize to system tray when closed"/>

        <CheckBox x:Name="AlwaysOnTopCheck"
                  Content="Keep window on top of other apps"
                  Foreground="{DynamicResource PrimaryTextBrush}"
                  Margin="0,0,0,4"
                  ToolTip="Keeps the Tiny Timers window above other windows so it doesn't get pushed behind whatever else you're focused on"/>

        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,16,0,16"/>

        <!-- Shortcuts -->
        <TextBlock Text="SHORTCUTS" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SectionHeaderBrush}" Margin="0,0,0,10"/>
        <TextBlock Text="Play / Pause / Resume"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Margin="0,0,0,8"
                   ToolTip="Starts, pauses, or resumes whichever timer is currently 'active'"/>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="HotkeyBox"
                     Grid.Column="0"
                     Height="28"
                     Padding="4"
                     IsReadOnly="True"
                     Focusable="False"
                     Cursor="Arrow"
                     VerticalContentAlignment="Center"
                     Background="{DynamicResource InputBackgroundBrush}"
                     Foreground="{DynamicResource InputForegroundBrush}"
                     BorderBrush="{DynamicResource InputBorderBrush}"
                     BorderThickness="1"/>
            <Button Grid.Column="1"
                    Content="Change..."
                    Width="70" Height="28"
                    Margin="8,0,0,0"
                    Click="ChangeHotkey_Click"
                    Background="{DynamicResource SecondaryButtonBackgroundBrush}"
                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </Grid>

        <TextBlock Text="Reset Active Timer"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Margin="0,0,0,8"
                   ToolTip="Resets whichever timer is currently 'active' back to its starting point"/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ResetHotkeyBox"
                     Grid.Column="0"
                     Height="28"
                     Padding="4"
                     IsReadOnly="True"
                     Focusable="False"
                     Cursor="Arrow"
                     VerticalContentAlignment="Center"
                     Background="{DynamicResource InputBackgroundBrush}"
                     Foreground="{DynamicResource InputForegroundBrush}"
                     BorderBrush="{DynamicResource InputBorderBrush}"
                     BorderThickness="1"/>
            <Button Grid.Column="1"
                    Content="Change..."
                    Width="70" Height="28"
                    Margin="8,0,0,0"
                    Click="ChangeResetHotkey_Click"
                    Background="{DynamicResource SecondaryButtonBackgroundBrush}"
                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </Grid>

        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,16,0,16"/>

        <!-- Timer files -->
        <TextBlock Text="TIMER FILES" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource SectionHeaderBrush}" Margin="0,0,0,10"/>
        <TextBlock Text="Location"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Margin="0,0,0,8"
                   ToolTip="Folder where each timer's live-updating .txt file is written"/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TimerFilesPathBox"
                     Grid.Column="0"
                     Height="28"
                     Padding="4"
                     IsReadOnly="True"
                     VerticalContentAlignment="Center"
                     Background="{DynamicResource InputBackgroundBrush}"
                     Foreground="{DynamicResource InputForegroundBrush}"
                     BorderBrush="{DynamicResource InputBorderBrush}"
                     BorderThickness="1"
                     ToolTip="Folder where each timer's live-updating .txt file is written"/>
            <Button Grid.Column="1"
                    Content="Browse..."
                    Width="70" Height="28"
                    Margin="8,0,0,0"
                    Click="Browse_Click"
                    Background="{DynamicResource SecondaryButtonBackgroundBrush}"
                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                    BorderThickness="0"
                    Cursor="Hand"/>
        </Grid>
        <Button Content="Reset to default"
                HorizontalAlignment="Left"
                Margin="0,4,0,12"
                Padding="0"
                Click="ResetLocation_Click"
                Background="Transparent"
                Foreground="{DynamicResource LinkTextBrush}"
                BorderThickness="0"
                FontSize="11"
                Cursor="Hand"/>

        <Button Content="Clear old timers"
                HorizontalAlignment="Left"
                Height="28"
                Padding="10,0"
                Click="ClearOldTimers_Click"
                ToolTip="Delete any leftover timer file(s) from existing or previous directories"
                Background="{DynamicResource SecondaryButtonBackgroundBrush}"
                Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                BorderThickness="0"
                Cursor="Hand"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel"
                    Width="80" Height="28" Margin="0,0,8,0"
                    Click="Cancel_Click"
                    Background="Transparent"
                    Foreground="{DynamicResource MutedTextBrush}"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Save"
                    Width="80" Height="28"
                    Click="Save_Click"
                    Background="{DynamicResource AccentBackgroundBrush}"
                    Foreground="{DynamicResource AccentForegroundBrush}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>
