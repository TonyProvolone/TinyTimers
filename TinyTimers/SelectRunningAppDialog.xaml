<Window x:Class="TinyTimers.SelectRunningAppDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select an Open App"
        Height="380" Width="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Currently open apps" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>

        <ListBox x:Name="AppList"
                 Grid.Row="1"
                 DisplayMemberPath="Display"
                 Background="{DynamicResource CardBackgroundBrush}"
                 Foreground="{DynamicResource PrimaryTextBrush}"
                 BorderBrush="{DynamicResource InputBorderBrush}"
                 BorderThickness="1"
                 MouseDoubleClick="AppList_MouseDoubleClick"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Refresh"
                    Width="70" Height="28" Margin="0,0,8,0"
                    Click="Refresh_Click"
                    Background="{DynamicResource SecondaryButtonBackgroundBrush}"
                    Foreground="{DynamicResource SecondaryButtonForegroundBrush}"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Cancel"
                    Width="70" Height="28" Margin="0,0,8,0"
                    Click="Cancel_Click"
                    Background="Transparent"
                    Foreground="{DynamicResource MutedTextBrush}"
                    BorderThickness="0"
                    Cursor="Hand"/>
            <Button Content="Select"
                    Width="70" Height="28"
                    Click="Select_Click"
                    Background="{DynamicResource AccentBackgroundBrush}"
                    Foreground="{DynamicResource AccentForegroundBrush}"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
